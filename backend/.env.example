# ─────────────────────────────────────────────────────────────────────────────
# Security Camera Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Default: SQLite (file-based, zero config, great for local/dev)
DATABASE_URL=sqlite:///./security_camera.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/security_camera

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080   # 7 days

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create a bot at https://t.me/BotFather, then paste the token here.
# Leave blank to disable Telegram features gracefully.
TELEGRAM_BOT_TOKEN=

# ── Webhook base URL (used for Telegram webhook registration) ─────────────────
# Must be a publicly reachable HTTPS URL when deploying.
# Example: https://mycamera.example.com
APP_BASE_URL=http://localhost:8000

# ── Media storage ─────────────────────────────────────────────────────────────
MEDIA_DIR=./media

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
